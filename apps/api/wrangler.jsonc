{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-14",
  // "compatibility_flags": [
  //   "nodejs_compat"
  // ],
  "vars": {
    "APP_ENV": "development",
  },
  "env": {
    "test": {
      "vars": {
        "APP_ENV": "test"
      }
    },
    "production": {
      "vars": {
        "APP_ENV": "production"
      }
    }
  }
