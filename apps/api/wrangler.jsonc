{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "api",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-14",
	// "compatibility_flags": [
	//   "nodejs_compat"
	// ],
	"vars": {
		"APP_ENV": "development",
	},
	"env": {
		"test": {
			"vars": {
				"APP_ENV": "test"
			}
		},
		"production": {
			"vars": {
				"APP_ENV": "production"
			}
		}
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ai-agent-local-auth",
			"database_id": "1b529b6d-7ad8-4eff-ada2-c32ae11a9c1f",
			"remote": true
		}
	]
